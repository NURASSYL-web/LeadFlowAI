rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function ownsSalon(salonId) {
      return salonId != null &&
        exists(/databases/$(database)/documents/salons/$(salonId)) &&
        get(/databases/$(database)/documents/salons/$(salonId)).data.ownerUid == request.auth.uid;
    }
    
    // Users: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Salons: only the owner can CRUD their salon
    match /salons/{salonId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.ownerUid == request.auth.uid) &&
        (request.resource == null || request.resource.data.ownerUid == request.auth.uid);
    }
    
    // Services: owner of the salon can CRUD services
    match /services/{serviceId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/salons/$(resource.data.salonId)) &&
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerUid == request.auth.uid;
      allow create: if request.auth != null;
    }
    
    // FAQ Items: same as services
    match /faqItems/{faqId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/salons/$(resource.data.salonId)) &&
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerUid == request.auth.uid;
      allow create: if request.auth != null;
    }
    
    // Inquiries: same as services
    match /inquiries/{inquiryId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/salons/$(resource.data.salonId)) &&
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerUid == request.auth.uid;
      allow create: if request.auth != null;
    }

    // WhatsApp conversations/messages for the current authenticated operator.
    // Webhook writes use Admin SDK and bypass rules; app reads need access.
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (
        resource.data.channel == 'telegram' ||
        resource.data.channel == 'manual' ||
        resource.data.ownerUid == request.auth.uid ||
        ownsSalon(resource.data.salonId)
      );

      allow write: if request.auth != null && (
        resource == null ||
        resource.data.ownerUid == request.auth.uid ||
        ownsSalon(resource.data.salonId)
      );

      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.channel == 'telegram' ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.channel == 'manual' ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.ownerUid == request.auth.uid ||
          ownsSalon(get(/databases/$(database)/documents/conversations/$(conversationId)).data.salonId)
        );

        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.ownerUid == request.auth.uid ||
          ownsSalon(get(/databases/$(database)/documents/conversations/$(conversationId)).data.salonId)
        );
      }
    }
  }
}
